generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  style       String
  color       String
  priceARS    Int
  description String?
  imageUrl    String?
  gradient    String?
  dimensions  String?
  stock       Int      @default(1)
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Order {
  id              String   @id @default(cuid())
  type            String
  status          String   @default("pending")
  customerName    String
  customerEmail   String
  customerPhone   String?
  items           String
  totalARS        Int
  mpPreferenceId  String?
  mpPaymentId     String?
  mpStatus        String?
  shippingAddress String?
  notes           String?
  canvasDataUrl   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
}
